# ============================================
# MINHAAJULHUDAA ENVIRONMENT CONFIGURATION
# ============================================
# This file contains all environment variables needed for the complete system
# Copy this to .env and fill in your actual values

# ============================================
# GITHUB DATABASE CONFIGURATION
# ============================================
# GitHub username (owner of the repository)
VITE_GITHUB_USER=your-github-username

# Repository name where data will be stored
VITE_GITHUB_REPO=your-repository-name

# GitHub Personal Access Token with repo permissions
# Generate at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=ghp_your_github_token_here

# GitHub branch for data storage (default: main)
VITE_GITHUB_BRANCH=main

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================

# PAYSTACK (Primary for Nigerian payments)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
VITE_PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# STRIPE (International payments)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
VITE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# FLUTTERWAVE (African payments)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key
VITE_FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key

# ============================================
# CLOUDINARY MEDIA MANAGEMENT
# ============================================
# Cloudinary cloud name
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key
VITE_CLOUDINARY_API_KEY=your_api_key

# Cloudinary API secret
VITE_CLOUDINARY_API_SECRET=your_api_secret

# Cloudinary upload preset (for unsigned uploads)
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ============================================
# EMAIL SERVICE CONFIGURATION
# ============================================
# SMTP endpoint or email service API endpoint
VITE_SMTP_ENDPOINT=smtp.gmail.com

# SMTP port (465 for SSL, 587 for TLS)
VITE_SMTP_PORT=587

# SMTP username (usually your email)
VITE_SMTP_USERNAME=your-email@domain.com

# SMTP password or app password
VITE_SMTP_PASSWORD=your_smtp_password

# From email address
VITE_SMTP_FROM=noreply@minhaajulhudaa.org

# Email service API key (if using SendGrid, Mailgun, etc.)
VITE_EMAIL_API_KEY=your_email_api_key

# ============================================
# ARCHIVE.ORG API INTEGRATION
# ============================================
# Archive.org API key (optional, for enhanced features)
VITE_ARCHIVE_ORG_API_KEY=your_archive_org_api_key

# Default Quran reciter identifier
VITE_DEFAULT_QURAN_RECITER=AbdulBaset_AbdulSamad_Mujawwad_128kbps

# ============================================
# APPLICATION SETTINGS
# ============================================
# Application base URL
VITE_APP_URL=http://localhost:3000

# API base URL (if different from app URL)
VITE_API_URL=http://localhost:3000/api

# Application environment (development, staging, production)
VITE_APP_ENV=development

# Enable debug mode
VITE_DEBUG=true

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT secret key for token generation
VITE_JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Session expiry time in seconds (default: 7 days)
VITE_SESSION_EXPIRY=604800

# Require email verification for new users
VITE_REQUIRE_EMAIL_VERIFICATION=true

# OTP expiry time in minutes
VITE_OTP_EXPIRY=10

# ============================================
# PLATFORM-SPECIFIC SETTINGS
# ============================================

# SCHOOL PLATFORM
VITE_SCHOOL_NAME=Minhaajulhudaa Islamic School
VITE_SCHOOL_CONTACT_EMAIL=school@minhaajulhudaa.org
VITE_SCHOOL_PHONE=+234-xxx-xxx-xxxx
VITE_SCHOOL_ADDRESS=Address Here

# MASJID PLATFORM
VITE_MASJID_NAME=Minhaajulhudaa Masjid
VITE_MASJID_LATITUDE=0.0
VITE_MASJID_LONGITUDE=0.0
VITE_MASJID_TIMEZONE=Africa/Lagos

# CHARITY PLATFORM
VITE_CHARITY_NAME=Minhaajulhudaa Charity
VITE_CHARITY_REGISTRATION_NUMBER=RC-xxxxx

# TRAVELS PLATFORM
VITE_TRAVELS_NAME=Minhaajulhudaa Travels
VITE_TRAVELS_LICENSE_NUMBER=TL-xxxxx

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================
# Google Maps API key (for location features)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Analytics tracking ID
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Social media links
VITE_FACEBOOK_URL=https://facebook.com/minhaajulhudaa
VITE_TWITTER_URL=https://twitter.com/minhaajulhudaa
VITE_INSTAGRAM_URL=https://instagram.com/minhaajulhudaa
VITE_YOUTUBE_URL=https://youtube.com/@minhaajulhudaa

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable specific features
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_SMS_NOTIFICATIONS=false
VITE_ENABLE_CLOUDINARY=true
VITE_ENABLE_SEARCH=true
VITE_ENABLE_ANALYTICS=true
